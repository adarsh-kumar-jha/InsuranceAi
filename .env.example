# ??????????????????????????????????????????????????????????????????????????????
# Insurance AI — LLM Configuration
#
# To switch providers:
#   1. Set LLM_PROVIDER to your chosen provider
#   2. Add the corresponding API key below
#   3. That's it — nothing else needs to change
# ??????????????????????????????????????????????????????????????????????????????

# Active provider (choose one):
#   groq | openai | together | fireworks | ollama | custom
LLM_PROVIDER=groq

# ?? API Keys (add only the one you use) ??????????????????????????????????????

# Groq (https://console.groq.com/keys) — fast inference, free tier available
GROQ_API_KEY=

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# Together AI (https://api.together.xyz/settings/api-keys)
TOGETHER_API_KEY=

# Fireworks AI (https://fireworks.ai/account/api-keys)
FIREWORKS_API_KEY=

# Custom / local — any OpenAI-compatible endpoint (e.g. vLLM, LM Studio, Ollama)
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama

# ?? Model Overrides (optional — sensible defaults chosen per provider) ????????
# Leave blank to use provider defaults. Set to override for a specific model.
#
# Provider default models:
#   groq:      llama-4-scout (guardrail/safety) | llama-3.3-70b-versatile (parser)
#   openai:    gpt-4o-mini (all agents)
#   together:  meta-llama/Llama-3.3-70B-Instruct-Turbo (all agents)
#   fireworks: accounts/fireworks/models/llama-v3p3-70b-instruct (all agents)
#   ollama:    llama3.3 (all agents)

GUARDRAIL_MODEL=
PARSER_MODEL=
PARSER_FALLBACK_MODEL=
SAFETY_MODEL=
